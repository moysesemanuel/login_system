{
  "name": "login-system-portfolio",
  "version": "1.0.0",
  "description": "Central de autenticação para ERP e Help Desk com Prisma e PostgreSQL.",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "seed:admin": "tsx scripts/create-admin.ts"
  },
  "keywords": [
    "login",
    "auth",
    "portfolio",
    "node",
    "typescript"
  ],
  "author": "Moyses Costa",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
